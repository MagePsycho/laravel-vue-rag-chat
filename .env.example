APP_NAME=AskDocs
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Postgres + pgvector (matches docker-compose.yml). Run `docker compose up -d` first.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rag
DB_USERNAME=rag
DB_PASSWORD=rag

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# RAG configuration
# ----------------------------------------------------------------------------
# Driver selects the embedding + chat backends:
#   fake      -> deterministic local stubs; NO API keys needed (default; tests use this too)
#   anthropic -> Voyage AI embeddings + Anthropic Claude for answers (needs keys below)
RAG_DRIVER=fake

# Vector dimension of stored embeddings. Must match the embedder output AND the
# vector(N) column created by the migration. The fake embedder produces this many dims.
# Voyage `voyage-3.5` outputs 1024 dims, so 1024 works for both drivers out of the box.
RAG_EMBED_DIM=1024

# Retrieval store: pgvector (default) or memory (no DB; handy for a quick spin)
RAG_STORE=pgvector

# How many chunks to retrieve per question, and how documents are chunked.
RAG_TOP_K=5
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150

# Static bearer token the MCP server uses to call the read-only /api/search endpoint.
RAG_API_TOKEN=local-dev-token

# Anthropic (answers) — only needed when RAG_DRIVER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Voyage AI (embeddings; Anthropic's recommended embeddings provider) — RAG_DRIVER=anthropic
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5
